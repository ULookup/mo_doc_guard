APP_ENV=dev
LOG_LEVEL=INFO
PORT=8080
ACCESS_LOG_ENABLED=0
RUNS_DIR=./runs
MATRIXONE_REPO_DIR=./repos/matrixone
DOCS_REPO_DIR=./repos/matrixorigin.io
