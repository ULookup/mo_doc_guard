MODELS_CONFIG_PATH=./configs/models.yaml
PROMPTS_CONFIG_PATH=./configs/prompts.yaml
QUALITY_GATES_CONFIG_PATH=./configs/quality_gates.yaml
MCP_AUTHOR_ENDPOINT=http://127.0.0.1:8787/invoke
MCP_REVIEWER_ENDPOINT=http://127.0.0.1:8787/invoke
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
MCP_GATEWAY_MOCK=false
MCP_GATEWAY_TIMEOUT_SECONDS=60
MCP_GATEWAY_RETRIES=2
